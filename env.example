# NEXUS-AI Frontend Environment Variables - EXAMPLE FILE
# --------------------------------------------------------
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# ✅ This file (.env.example) is safe to commit to GitHub.
# ❌ The actual .env file must NEVER be committed.

# URL of your running backend (Express server)
# - Local development:   http://localhost:5000/api
# - After deployment:    https://your-backend-url.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App name (optional)
NEXT_PUBLIC_APP_NAME=NEXUS-AI
