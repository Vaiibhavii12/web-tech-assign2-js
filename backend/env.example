# NEXUS-AI Backend Environment Variables - EXAMPLE FILE
# -------------------------------------------------------
# Copy this file to backend/.env and fill in your values.
#   cp backend/.env.example backend/.env
#
# ✅ This file (.env.example) is safe to commit to GitHub.
# ❌ The actual .env file must NEVER be committed.

# Server
PORT=5000
NODE_ENV=development

# MongoDB Connection
# - Local:   mongodb://localhost:27017/nexus-ai
# - Atlas:   mongodb+srv://<username>:<password>@cluster0.mongodb.net/nexus-ai
MONGODB_URI=mongodb://localhost:27017/nexus-ai

# JWT Secret — use a long, random string in production
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# CORS — frontend origin
CORS_ORIGIN=http://localhost:3000

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
