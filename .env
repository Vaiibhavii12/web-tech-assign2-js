# NEXUS-AI Frontend Environment Variables
# -----------------------------------------
# This file is for the Next.js frontend only.
# Backend has its own .env inside the /backend folder.
#
# ⚠️  NEVER commit this file to GitHub.
#     Make sure .env is listed in your .gitignore.

# URL of your running backend (Express server)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# App name (optional, used for display purposes)
NEXT_PUBLIC_APP_NAME=NEXUS-AI
